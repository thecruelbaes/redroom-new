# Базовый URL сайта (для sitemap/robots/canonical). Прод — https://redroomstudio.ru
NEXT_PUBLIC_SITE_URL=

# Подтверждение прав в Яндекс.Вебмастере (необязательно).
NEXT_PUBLIC_YANDEX_VERIFICATION=
